# Postgres connection (defaults match docker-compose.yml)
DATABASE_URL=postgresql://rag:rag@localhost:5432/scholargraph

# Which LLM to use for the intelligence pipeline
LLM_BACKEND=gemini       # gemini | ollama | openrouter
# LLM_MODEL=gemini-flash-latest   # default for gemini
# LLM_MODEL=qwen2.5:7b-instruct   # default for ollama
# LLM_MODEL=qwen/qwen-2.5-7b-instruct    # default for openrouter

# Required when LLM_BACKEND=gemini
GOOGLE_API_KEY=

# Used when LLM_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434

# Used when LLM_BACKEND=openrouter
OPENROUTER_API_KEY=

# Frontend origins allowed by CORS (comma-separated). Defaults cover Next.js, Vite, and common dev ports.
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
